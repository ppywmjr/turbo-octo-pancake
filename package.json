{
  "name": "turbo-octo-pancake",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "mutate": "stryker run",
    "mutate:baseline": "node --experimental-strip-types scripts/update-mutation-baseline.ts",
    "mutate:compare": "node --experimental-strip-types scripts/compare-mutation-score.ts",
    "test:watch": "vitest",
    "ai:test:all": "vitest run tests 2>&1 | tail -30",
    "ai:test:unit": "vitest run tests/unit 2>&1 | tail -30",
    "ai:test:unit:verbose:fail": "pnpm vitest run tests/unit --reporter=verbose 2>&1 | grep -A 30 \"FAIL\"",
    "ai:coverage": "vitest run --coverage 2>&1 | tail -30",
    "ai:mutate": "stryker run 2>&1 | tail -80",
    "ai:mutate:survived": "pnpm run mutate 2>&1 | grep -A 5 \"\\[Survived\\]\""
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.8",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}